# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Rust 遵循 rustfmt 默认(4 空格)
[*.rs]
indent_size = 4

# Makefile 必须使用 Tab 缩进
[Makefile]
indent_style = tab

# Markdown 行尾空格有语义(硬换行),不做裁剪
[*.{md,markdown}]
trim_trailing_whitespace = false
